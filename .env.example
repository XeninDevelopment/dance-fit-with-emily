# ---------------------------------------------------------------------------
# Copy this file to `.env` and fill in real values. See SETUP.md for where each
# value comes from. Both Next.js and the Prisma CLI read `.env`.
# ---------------------------------------------------------------------------

# --- Supabase (Postgres) — Project Settings > Database > Connection string ---
# DATABASE_URL = "Transaction" pooler (port 6543, ?pgbouncer=true) — used by the app at runtime.
# DIRECT_URL   = "Session"/direct connection (port 5432) — used by Prisma migrations only.
DATABASE_URL="postgresql://postgres.PROJECT:PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.PROJECT:PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres"

# --- Stripe — Developers > API keys (use TEST keys first) ---
STRIPE_SECRET_KEY="sk_test_..."
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."
# From the webhook endpoint you create (or `stripe listen` for local dev).
STRIPE_WEBHOOK_SECRET="whsec_..."

# --- Email (Resend) — Dashboard > API Keys. Confirmation emails are skipped if unset. ---
RESEND_API_KEY="re_..."
# Optional overrides; defaults are the verified domain + the studio contact address.
# EMAIL_FROM="Dance Fit with Emily <hello@dancefitwithemily.org>"
# EMAIL_REPLY_TO="dancefitwithemily@outlook.com"

# --- Scheduler (waitlist offer escalation) — any long random string; the cron/pinger must
# send it as "Authorization: Bearer <value>" to /api/cron/waitlist. ---
CRON_SECRET="another-long-random-string"

# --- Admin auth ---
ADMIN_PASSWORD="pick-a-strong-password"
AUTH_SECRET="a-long-random-string-at-least-32-chars"

# --- App config ---
NEXT_PUBLIC_BASE_URL="http://localhost:3000"
NEXT_PUBLIC_SITE_NAME="Dance Fit with Emily"
DEFAULT_CURRENCY="gbp"

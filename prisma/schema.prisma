// Prisma schema for the Dance Fit with Emily booking system.
// Prisma 7: connection URL lives in prisma.config.ts; runtime uses a driver adapter.
// Docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

/// A dance class people can join. One class has one public join link and many bookings.
model Class {
  id            String    @id @default(cuid())
  token         String    @unique // unguessable; used in the public /class/{token} join link
  danceType     String // class name / dance type
  classDateTime DateTime
  location      String? // optional venue note
  spotifyUrl    String? // optional public Spotify playlist/album link, previewed on the join page
  themed        Boolean  @default(false) // a special / themed class, shown separately from regular ones
  amount        Int // price per person, minor units (e.g. pence)
  currency      String    @default("gbp") // lowercase ISO 4217
  capacity      Int? // max spots; null = unlimited
  closed        Boolean   @default(false) // admin can stop new joins
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  bookings      Booking[]
  spotHolds     SpotHold[]
  waitlist      WaitlistEntry[]
  spotOffers    SpotOffer[]

  @@index([classDateTime])
}

/// Someone waiting for a spot in a full class. FIFO by position; email lowercased at insert.
model WaitlistEntry {
  id        String   @id @default(cuid())
  classId   String
  class     Class    @relation(fields: [classId], references: [id], onDelete: Cascade)
  name      String
  email     String
  position  Int // FIFO order (gaps are fine; order by position, createdAt)
  offeredAt DateTime? // set when this entry gets a tier-1 exclusive offer (missed window = lost priority)
  converted Boolean  @default(false) // booked a spot via an offer
  createdAt DateTime @default(now())

  @@unique([classId, email])
  @@index([classId, position])
}

/// A freed spot reserved for the waitlist. Tier 1: exclusive to the first in line (30 min);
/// tier 2: first-come for the whole waitlist (30 min more); then EXPIRED = open to the public.
/// A HELD offer counts toward capacity so the public can't take the reserved seat.
model SpotOffer {
  id             String      @id @default(cuid())
  classId        String
  class          Class       @relation(fields: [classId], references: [id], onDelete: Cascade)
  claimToken     String      @unique // unguessable; possession of the emailed link = authorisation
  status         OfferStatus @default(HELD)
  tier           Int         @default(1)
  holderEntryId  String? // the tier-1 exclusive holder (null once created straight at tier 2)
  tier1ExpiresAt DateTime
  tier2ExpiresAt DateTime
  createdAt      DateTime    @default(now())

  @@index([classId, status])
  @@index([status, tier1ExpiresAt])
  @@index([status, tier2ExpiresAt])
}

enum OfferStatus {
  HELD // reserved, claimable via the emailed link
  CLAIMED // a booking consumed this offer's seat
  EXPIRED // both windows passed — the seat is public again
}

/// A short-lived seat reservation. Created during checkout so two concurrent buyers can't
/// oversell a class; counts toward capacity until it expires or the payment succeeds (then
/// it's cleared). Reused later to hold a freed spot for a waitlist offer.
model SpotHold {
  id              String   @id @default(cuid())
  classId         String
  class           Class    @relation(fields: [classId], references: [id], onDelete: Cascade)
  paymentIntentId String?  @unique // set once the PaymentIntent exists
  expiresAt       DateTime // the hold stops counting once this passes
  createdAt       DateTime @default(now())

  @@index([classId, expiresAt])
}

/// One person's place on a class. One booking == one Stripe PaymentIntent
/// (manual cash bookings have no PaymentIntent).
model Booking {
  id              String        @id @default(cuid())
  classId         String
  class           Class         @relation(fields: [classId], references: [id], onDelete: Cascade)
  customerName    String
  customerEmail   String
  customerPhone   String?
  status          BookingStatus @default(PENDING)
  manual          Boolean       @default(false) // added by the admin (e.g. paid in cash)
  paymentIntentId String?       @unique
  clientSecret    String? // cached; reconciled against Stripe on each read
  paidAt          DateTime?
  confirmationEmailSentAt DateTime? // set once the branded confirmation email is sent (exactly-once claim)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@index([classId])
  @@index([status])
}

enum BookingStatus {
  PENDING // booking created, PaymentIntent created, not yet paid
  PROCESSING // async payment method in flight
  PAID
  FAILED
  CANCELED
}

/// A customer review / case study, shown on the public site. Managed by the admin.
model Review {
  id        String   @id @default(cuid())
  name      String // who left it
  title     String? // optional headline, e.g. for a case study
  quote     String // the review text (can be long for a case study)
  rating    Int? // optional 1–5 stars
  featured  Boolean  @default(false) // highlight as a case study
  pending   Boolean  @default(false) // public submissions await admin approval; hidden from the site until approved
  createdAt DateTime @default(now())

  @@index([featured])
  @@index([pending])
}
